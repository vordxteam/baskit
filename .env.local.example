# API Configuration Environment Template
# Copy this file to .env.local and update with your actual values

# ============================================================================
# API Server Configuration (REQUIRED)
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ============================================================================
# API Client Settings (Optional)
# ============================================================================
# Request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

# Enable API debugging in console
NEXT_PUBLIC_DEBUG_API=false

# ============================================================================
# Authentication Settings (Optional)
# ============================================================================
# Token refresh interval in milliseconds (default: 5 minutes)
NEXT_PUBLIC_AUTH_REFRESH_INTERVAL=300000

# ============================================================================
# OAuth Providers (Optional - if using OAuth)
# ============================================================================
# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Microsoft OAuth
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=

# Facebook OAuth
NEXT_PUBLIC_FACEBOOK_APP_ID=

# ============================================================================
# Feature Flags (Optional)
# ============================================================================
NEXT_PUBLIC_ENABLE_2FA=true
NEXT_PUBLIC_ENABLE_OAUTH=true
NEXT_PUBLIC_ENABLE_PASSWORD_RESET=true

# ============================================================================
# Application Settings
# ============================================================================
# Environment (development, staging, production)
NODE_ENV=development

# Application URL
# NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=https://baskitbackend.vordx.com

# ============================================================================
# NOTES:
# ============================================================================
# - Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Keep sensitive information out of client-side environment variables
# - Use server-side environment variables for secrets (without NEXT_PUBLIC_)
# - Never commit .env.local to version control
# - Update NEXT_PUBLIC_API_URL to match your backend API address
# ============================================================================
